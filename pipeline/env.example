# ---------------------------------------------------------------
# SAI Protocol — Phase 1 EOA Pipeline Environment
# Copy this to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------

# A throwaway EOA private key — generate a fresh one, fund it
# with a tiny amount of Base Sepolia ETH for gas, throw it away
# after Phase 1. Never reuse this key for anything real.
THROWAWAY_PRIVATE_KEY=0x...

# Your deployed SoulAccount proxy address from SoulFactoryDeploy
# This is the clone address, NOT the implementation address.
SOUL_ACCOUNT_ADDRESS=0x...

# Pimlico bundler RPC endpoint for Base Sepolia.
# Get this from https://dashboard.pimlico.io — free tier is fine.
PIMLICO_RPC_URL=https://api.pimlico.io/v2/base-sepolia/rpc?apikey=...

# Base Sepolia RPC for direct chain reads (Alchemy, Infura, or public)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
